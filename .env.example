# herdr-push config
# Place this file at: herdr plugin config-dir herdr.push
# Then copy .env.example to .env and edit

# Relay URL (required)
# Use cloudflared tunnel URL, Tailscale IP, or LAN address
HERDR_RELAY="https://your-tunnel.trycloudflare.com"

# Relay token (optional)
# Must match HERDR_RELAY_TOKEN on the relay. Sent as ?token= on each push;
# without it a token-protected relay returns 401.
# HERDR_RELAY_TOKEN="your-shared-secret"
